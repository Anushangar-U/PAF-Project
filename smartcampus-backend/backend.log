    create table attachments (
        id bigint generated by default as identity,
        ticket_id bigint not null,
        uploaded_at timestamp(6),
        file_name varchar(255) not null,
        file_type varchar(255),
        file_url varchar(255) not null,
        primary key (id)
    )
Hibernate: 
    create table comments (
        created_at timestamp(6),
        id bigint generated by default as identity,
        ticket_id bigint not null,
        author_name varchar(255) not null,
        author_role varchar(255),
        content TEXT not null,
        primary key (id)
    )
Hibernate: 
    create table resources (
        capacity integer not null,
        id bigint generated by default as identity,
        availability_windows varchar(255),
        location varchar(255),
        name varchar(255) not null,
        status varchar(255) not null,
        type varchar(255) not null,
        primary key (id)
    )
Hibernate: 
    create table tickets (
        created_at timestamp(6),
        id bigint generated by default as identity,
        reported_by_id bigint,
        updated_at timestamp(6),
        assigned_technician varchar(255),
        category varchar(255) not null check (category in ('ELECTRICAL','PLUMBING','IT_EQUIPMENT','HVAC','STRUCTURAL','SAFETY','OTHER')),
        contact_email varchar(255),
        contact_name varchar(255),
        description TEXT not null,
        location varchar(255),
        priority varchar(255) not null check (priority in ('LOW','MEDIUM','HIGH')),
        resolution_notes TEXT,
        status varchar(255) not null check (status in ('OPEN','IN_PROGRESS','RESOLVED','CLOSED','REJECTED')),
        title varchar(255) not null,
        primary key (id)
    )
Hibernate: 
    create table users (
        id bigint generated by default as identity,
        email varchar(255) not null unique,
        name varchar(255) not null,
        role varchar(255) not null check (role in ('USER','TECHNICIAN','ADMIN')),
        primary key (id)
    )
